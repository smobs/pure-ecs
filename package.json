{
  "name": "pure-ecs",
  "version": "0.1.0",
  "description": "A pure functional Entity Component System for PureScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smobs/pure-ecs.git"
  },
  "scripts": {
    "build": "spago build",
    "test": "spago build && node --input-type=module -e \"import('./output-es/Test.Main/index.js').then(m => m.main());\"",
    "docs": "spago docs",
    "clean": "rm -rf output output-es .spago",
    "build:demo": "spago build && node build-demo.js",
    "bench": "spago bundle -p pure-ecs-bench --output output-es && node bench/bench-out.mjs",
    "serve": "python3 -m http.server 8000 --directory docs"
  },
  "keywords": [
    "purescript",
    "ecs",
    "entity-component-system",
    "functional",
    "game-development"
  ],
  "devDependencies": {
    "esbuild": "^0.19.0",
    "purescript": "^0.15.15",
    "purs-backend-es": "^1.4.3",
    "spago": "next"
  }
}
